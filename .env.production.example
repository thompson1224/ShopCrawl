# ===========================================
# ShopCrawl VPS Production Environment
# ===========================================
# 복사하여 .env 파일로 저장 후 필요값 입력

# 환경
APP_ENV=production
PORT=8000

# JWT 서명 키 (필수)
# 생성: openssl rand -hex 32
SECRET_KEY=change_this_to_strong_random_secret

# Google AI (RAG/AI 검색용)
# https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your_google_api_key_here

# 네이버 로그인 OAuth
# https://developers.naver.com/apps
NAVER_CLIENT_ID=your_naver_client_id
NAVER_CLIENT_SECRET=your_naver_client_secret

# 관리자 비밀번호 (강력한 랜덤 문자열 권장)
# 생성: openssl rand -hex 32
ADMIN_SECRET=change_this_to_strong_random_string

# 기본 URL (도메인 변경 필수!)
BASE_URL=https://shop.yourdomain.com

# 선택: 데이터 보존 기간 (기본 30일)
CLEANUP_DAYS=30
